# ── Postgres ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ── Docker (dev) ───────────────────────────────────────────────────────────────
# Name of the Docker network session containers join so Nginx can proxy to them.
# Run: docker network ls | grep compose
# Usually: compose_internal  (project folder name + "_internal")
DOCKER_NETWORK=compose_internal

# ── Security ───────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32-byte-hex-string

# ── Auth methods ───────────────────────────────────────────────────────────────
# Comma-separated list of enabled login methods: oidc, local, ldap
# Examples:
#   AUTH_METHODS=oidc            # OIDC only (default)
#   AUTH_METHODS=local           # username/password only
#   AUTH_METHODS=ldap            # LDAP only
#   AUTH_METHODS=oidc,local      # OIDC + local login form
#   AUTH_METHODS=oidc,local,ldap # all three
AUTH_METHODS=oidc

# ── OIDC (external provider — no local Keycloak needed) ───────────────────────
# Leave blank to disable OIDC even if it's listed in AUTH_METHODS.
# Examples:
#   Google:     https://accounts.google.com
#   Azure AD:   https://login.microsoftonline.com/{tenant}/v2.0
#   Okta:       https://{domain}.okta.com
#   Auth0:      https://{domain}.auth0.com
#   Authentik:  https://auth.example.com/application/o/{slug}
OIDC_ISSUER=https://accounts.google.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
# Comma-separated scopes (include 'groups' if your provider supports it)
OIDC_SCOPES=openid email profile groups
# Claim name that contains group list (provider-specific)
OIDC_GROUPS_CLAIM=groups
# Label for the SSO button on the login page
OIDC_BUTTON_LABEL=Sign in with your organisation

# ── LDAP ───────────────────────────────────────────────────────────────────────
# Required only when AUTH_METHODS includes 'ldap'.
LDAP_HOST=ldap.example.com
LDAP_PORT=389
# Service account used to search for users (leave blank for anonymous bind)
LDAP_BIND_DN=cn=lwp-service,dc=example,dc=com
LDAP_BIND_PASSWORD=service-account-password
# Base DN to search under
LDAP_BASE_dn=dc=example,dc=com
# Filter to find a user — {username} is substituted with what the user types
# OpenLDAP:     (uid={username})
# Active Directory: (sAMAccountName={username})
LDAP_USER_FILTER=(uid={username})
# Attribute that holds the user's email address
LDAP_USER_ATTR_EMAIL=mail
# Attribute that holds the display name
LDAP_USER_ATTR_DISPLAY_NAME=cn
# TLS mode: none | ldaps | starttls
LDAP_TLS=none
# Attribute listing group membership (Active Directory: memberOf)
LDAP_GROUPS_ATTR=memberOf

# ── App ────────────────────────────────────────────────────────────────────────
LWP_BASE_URL=http://localhost
# Container image used for "web" type apps (Chrome in --app kiosk mode)
KIOSK_IMAGE=lwp-kiosk
TZ=Europe/Amsterdam

# ── Persistent home volumes (Kubernetes only) ──────────────────────────────────
# StorageClass to use for per-user home PVCs (must support ReadWriteOnce).
# For multi-session / multi-node use: set an RWX StorageClass (NFS, CephFS, Longhorn).
# HOME_STORAGE_CLASS=standard
# Size of each user's home PVC.
# HOME_PVC_SIZE=5Gi

# ── Ports (dev) ────────────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
