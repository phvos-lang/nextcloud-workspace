# Copy to secrets.yaml and fill in values. NEVER commit secrets.yaml.
# Apply with: kubectl apply -f k8s/overlays/prod/secrets.yaml
#
# Generate secret-key: python -c "import secrets; print(secrets.token_hex(32))"
apiVersion: v1
kind: Secret
metadata:
  name: lwp-secrets
  namespace: lwp
type: Opaque
stringData:
  postgres-password: "CHANGE_ME"
  database-url: "postgresql+asyncpg://lwp:CHANGE_ME@postgres:5432/lwp"
  secret-key: "CHANGE_ME_32_BYTE_HEX"
  oidc-issuer: "https://accounts.google.com"
  oidc-client-id: "CHANGE_ME"
  oidc-client-secret: "CHANGE_ME"
---
# TLS certificate (bring your own — no Let's Encrypt)
apiVersion: v1
kind: Secret
metadata:
  name: lwp-tls
  namespace: lwp
type: kubernetes.io/tls
data:
  # base64-encoded PEM cert and key:
  # tls.crt: $(base64 -w0 < your-cert.pem)
  # tls.key: $(base64 -w0 < your-key.pem)
  tls.crt: ""
  tls.key: ""
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: lwp-config
  namespace: lwp
data:
  # MUST match the external URL users hit; the OIDC redirect_uri is
  # {base-url}/api/auth/oidc/callback and must be registered in your IdP.
  base-url: "https://lwp.example.com"
  # Optional overrides (omit to use backend defaults):
  auth-methods: "oidc,local"
  oidc-button-label: "Sign in with your organisation"
  oidc-scopes: "openid email profile groups"
  oidc-groups-claim: "groups"
