# mtail program — turns nginx's per-session access log into Prometheus counters.
# Aggregate only (no per-token labels) to keep cardinality bounded.
counter nginx_session_bytes_sent_total
counter nginx_session_bytes_received_total
counter nginx_session_requests_total

/lwp_sess sent=(?P<sent>\d+) recv=(?P<recv>\d+)/ {
  nginx_session_bytes_sent_total += $sent
  nginx_session_bytes_received_total += $recv
  nginx_session_requests_total++
}
