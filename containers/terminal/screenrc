# LWP web terminal — system-wide screen defaults (/etc/screenrc).
# Users can override anything here with their own ~/.screenrc — screen reads
# /etc/screenrc first and the user's file second, so personal settings win
# (the home directory is persistent, drop a ~/.screenrc there and relaunch).

startup_message off
vbell off
defscrollback 10000
term screen-256color

# Full-screen TUI apps (vim, htop, opencode): without this, screen's default
# alt-screen handling leaves stale content behind and redraws wrong —
# "layout is off". altscreen on gives them a correct dedicated buffer.
altscreen on

# 24-bit colour pass-through — without it, apps designed for truecolor
# themes (opencode) get quantized to 256 colours and look off.
truecolor on
termcapinfo xterm*:Tc

# ttyd doesn't set SHELL — force a login bash (new tabs spawn it too), so
# profile.d (nvm/node PATH) is loaded
shell -/bin/bash

# Tab title follows the running command, falls back to bash
shelltitle "$ |bash"

# Don't switch to the alternate screen on attach/detach — keeps the browser
# scrollback usable
termcapinfo xterm* ti@:te@

# Footer: "terminal:" + window tabs, current tab highlighted. No date/time.
#   terminal: 0 bash  [1 bash]  2 vim
hardstatus alwayslastline
hardstatus string '%{= kG}terminal:%{= kw} %-w%{= bW} %n %t %{-}%+w'
